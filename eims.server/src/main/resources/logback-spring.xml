<?xml version="1.0" encoding="UTF-8"?>
<configuration>
	<include resource="org/springframework/boot/logging/logback/base.xml" />

	<appender name="dailyRollingFileAppender" class="ch.qos.logback.core.rolling.RollingFileAppender">
		<prudent>true</prudent>
		<rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
			<fileNamePattern>/logs/jboss/opseim01_18080/eims_logs/application.%d{yyyy-MM-dd}.log</fileNamePattern>
			<maxHistory>30</maxHistory>
		</rollingPolicy>
		<filter class="ch.qos.logback.classic.filter.ThresholdFilter">
			<level>INFO</level>
		</filter>

		<encoder>
			<charset>UTF-8</charset>
			<pattern>%d{yyyy:MM:dd HH:mm:ss.SSS} %-5level --- [%thread] %logger{35} : %msg %n</pattern>
		</encoder>
	</appender>

	<logger name="org.springframework" level="ERROR" />
	<logger name="org.thymeleaf" level="ERROR" />
	<logger name="org.hibernate.SQL" level="ERROR" />
	<logger name="org.quartz.core" level="ERROR" />
	<logger name="org.h2.server.web" level="ERROR" />
	<logger name="org.apache.http.wire" level="ERROR" />
	

	<logger name="eims.server" level="DEBUG" />
	<logger name="eims.server.dao" level="DEBUG" />
	<logger name="org.mybatis.spring" level="ERROR" />
	<logger name="eims.web.dao.MetabsDao" level="ERROR" />
	<logger name="eims.web.service.MetaService" level="ERROR" />
	
	
	

	<root level="DEBUG">
		<appender-ref ref="dailyRollingFileAppender" />
	</root>
</configuration>